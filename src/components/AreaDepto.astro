---
import Base from '../layouts/Base.astro';
import MapEmbed from './MapEmbed.astro';
import { site, waLink } from '../data/site';
import { servicios } from '../data/servicios';
import { departamentos, type Departamento } from '../data/departamentos';
import { getCiudad } from '../data/ciudades';

interface Props { d: Departamento; }
const { d } = Astro.props;

const ciudades = d.ciudades.map((slug) => getCiudad(slug)).filter(Boolean);
const otros = departamentos.filter((x) => x.slug !== d.slug).slice(0, 4);

const h1 = `Contenedores y construcción modular en ${d.nombre}`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Contenedores y módulos en ${d.nombre}`,
  description: d.metaDesc,
  provider: { '@id': `${site.url}/#multitainer` },
  areaServed: { '@type': 'AdministrativeArea', name: `Departamento de ${d.nombre}` },
};
const faqSchema = d.faqs.length ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: d.faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
} : null;
const schema = faqSchema ? [serviceSchema, faqSchema] : [serviceSchema];
---
<Base title={d.metaTitle} titleTail={d.titleTail} description={d.metaDesc} schema={schema}>
  <section class="phero"><div class="wrap">
    <div class="crumbs">
      <a href="/">Inicio</a><span>›</span>
      <a href="/areas-de-servicio/">Áreas</a><span>›</span>
      {d.nombre}
    </div>
    <span class="eyebrow">Cobertura departamental</span>
    <h1>{h1}</h1>
    <p class="lead">{d.hero}</p>
    <div class="cta-row"><a class="btn btn-amber" href={waLink(`Hola Multitainer, estoy en ${d.nombre} y quiero una cotización.`)} target="_blank" rel="noopener">Cotizar en {d.nombre} →</a></div>
  </div></section>

  <section class="pad"><div class="wrap">
    <div class="prose">
      {d.intro.map((p) => <p>{p}</p>)}
    </div>
  </div></section>

  <section class="pad" style="padding-top:0"><div class="wrap">
    <div class="geo">
      <div class="geo-map"><MapEmbed query={d.mapQuery} zoom={d.mapZoom} title={d.nombre} /></div>
      <div class="geo-ficha">
        <span class="eyebrow">El departamento</span>
        <h2>{d.nombre}, de punta a punta</h2>
        <p>{d.conocidoPor}</p>
        <ul class="refs">{d.referencias.map((r) => <li>{r}</li>)}</ul>
      </div>
    </div>
  </div></section>

  {ciudades.length > 0 && (
    <section class="pad" style="padding-top:0"><div class="wrap">
      <div class="head" style="margin-bottom:24px"><span class="eyebrow">Dónde trabajamos en {d.nombre}</span><h2>Ciudades que cubrimos</h2></div>
      <div class="pgrid">
        {ciudades.map((ci) => (
          <a class="pcard" href={`/areas-de-servicio/${ci!.departamentoSlug}/${ci!.slug}/`}>
            <div class="body">
              <div class="cat">Área de servicio</div>
              <h3>{ci!.nombre}</h3>
              <p>{ci!.hero}</p>
              <div class="arr" style="margin-top:14px;font-family:var(--h);font-weight:800;text-transform:uppercase;font-size:13px;letter-spacing:.06em;color:var(--amber)">Ver {ci!.nombre} →</div>
            </div>
          </a>
        ))}
      </div>
    </div></section>
  )}

  <section class="pad" style="padding-top:0"><div class="wrap">
    <div class="head" style="margin-bottom:24px"><span class="eyebrow">Lo que hacemos en {d.nombre}</span><h2>Nuestros servicios</h2></div>
    <div class="svc">
      {servicios.map((s) => (
        <a class="card" href={`/servicios/${s.slug}/`}>
          <div class="ic"><svg viewBox="0 0 24 24" set:html={s.icon}></svg></div>
          <h3>{s.nombre}</h3>
          <p>{s.hero}</p>
          <div class="arr">Ver {s.nombre.toLowerCase()} →</div>
        </a>
      ))}
    </div>
  </div></section>

  {d.faqs.length > 0 && (
    <section class="pad" style="padding-top:0"><div class="wrap">
      <div class="head"><span class="eyebrow">Preguntas frecuentes</span><h2>Trabajos en {d.nombre}</h2></div>
      <div class="faq">
        {d.faqs.map((f) => (<details><summary>{f.q}</summary><p>{f.a}</p></details>))}
      </div>
    </div></section>
  )}

  <section class="pad zones" style="padding-bottom:64px"><div class="wrap">
    <div class="head" style="margin-bottom:18px"><span class="eyebrow">Cobertura nacional</span><h2>Otros departamentos</h2></div>
    <div class="chips">
      {otros.map((o) => <a class="chip" href={`/areas-de-servicio/${o.slug}/`}>{o.nombre}</a>)}
      <a class="chip" href="/areas-de-servicio/">Ver todas las áreas</a>
    </div>
  </div></section>

  <section class="band">
    <span class="eyebrow">Hablemos hoy</span>
    <h2>Llegamos a todo {d.nombre}</h2>
    <p>Contanos dónde estás y qué necesitás. Coordinamos la entrega e instalación.</p>
    <a class="btn btn-amber" href={waLink(`Hola Multitainer, estoy en ${d.nombre} y quiero una cotización.`)} target="_blank" rel="noopener">Escribir por WhatsApp →</a>
  </section>
</Base>

<style>
  .geo { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 28px; align-items: start; }
  .geo-ficha .eyebrow { margin-bottom: 8px; display: inline-block; }
  .geo-ficha h2 { margin: 0 0 10px; }
  .refs { margin: 12px 0 16px; padding-left: 18px; }
  .refs li { margin: 4px 0; }
  @media (max-width: 820px) { .geo { grid-template-columns: 1fr; } }
</style>

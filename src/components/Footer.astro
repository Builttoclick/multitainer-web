---
import { site } from '../data/site';
import { servicios } from '../data/servicios';
import { zonas } from '../data/zonas';
const year = new Date().getFullYear();
---
<footer class="ft">
  <div class="wrap">
    <div class="ft-grid">
      <!-- Marca + NAP + mapa -->
      <div>
        <div class="fbrand">MULTITAINER</div>
        <p class="ft-about">Construcción modular, alquiler y venta de contenedores en Asunción y Gran Asunción. Oficinas, obradores, vestuarios y showrooms llave en mano.</p>
        <div class="ft-nap" style="margin-top:16px">
          <b>{site.legalName}</b><br />
          {site.addressFull}<br />
          <a href={`tel:+${site.phoneIntl}`}><b>{site.phone}</b></a> · <a href={site.whatsapp} target="_blank" rel="noopener">{site.whatsappLabel}</a><br />
          <a href={`mailto:${site.email}`}>{site.email}</a><br />
          {site.hours}
        </div>
        {site.gbpEmbed
          ? <iframe class="ft-map" src={site.gbpEmbed} loading="lazy" title="Ubicación de Multitainer en Google Maps" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
          : <div class="ft-map-ph">Mapa de Google Business · pendiente de pegar el embed real</div>}
      </div>

      <!-- Servicios -->
      <div>
        <h5>Servicios</h5>
        <ul>
          {servicios.map((s) => <li><a href={`/servicios/${s.slug}/`}>{s.nombre}</a></li>)}
          <li><a href="/servicios/"><b>Ver todos →</b></a></li>
        </ul>
      </div>

      <!-- Áreas -->
      <div>
        <h5>Áreas de servicio</h5>
        <ul>
          {zonas.slice(0, 6).map((z) => <li><a href={`/areas-de-servicio/${z.slug}/`}>{z.nombre}</a></li>)}
          <li><a href="/areas-de-servicio/"><b>Ver todas →</b></a></li>
        </ul>
      </div>

      <!-- Empresa -->
      <div>
        <h5>Empresa</h5>
        <ul>
          <li><a href="/proyectos/">Proyectos</a></li>
          <li><a href="/sobre-nosotros/">Sobre nosotros</a></li>
          <li><a href="/contacto/">Contacto</a></li>
          <li><a href={site.whatsapp} target="_blank" rel="noopener">WhatsApp</a></li>
          {site.instagram && <li><a href={site.instagram} target="_blank" rel="noopener">Instagram</a></li>}
          {site.facebook && <li><a href={site.facebook} target="_blank" rel="noopener">Facebook</a></li>}
        </ul>
        <a class="btn btn-amber" style="margin-top:14px" href={site.whatsapp} target="_blank" rel="noopener">Cotizar ahora</a>
      </div>
    </div>

    <div class="ft-bot">
      <span>© {year} {site.legalName}. Todos los derechos reservados.</span>
      <span>Hecho por <a href="https://builttoclick.com" target="_blank" rel="noopener">Built to Click</a></span>
    </div>
  </div>
</footer>

---
// Render de las 9 zonas legacy de Gran Asunción (slugs preservados, rankean).
// Markup idéntico al [zona].astro original + un mapa embebido.
import Base from '../layouts/Base.astro';
import MapEmbed from './MapEmbed.astro';
import { site, waLink } from '../data/site';
import { servicios } from '../data/servicios';
import { zonas } from '../data/zonas';

const { z, i } = Astro.props;
const vecinas = [zonas[(i + 1) % zonas.length], zonas[(i + 2) % zonas.length]];

const h1 = `Contenedores y construcción modular en ${z.nombre}`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Contenedores y módulos en ${z.nombre}`,
  description: z.metaDesc,
  provider: { '@id': `${site.url}/#multitainer` },
  areaServed: { '@type': 'City', name: z.nombre },
};
const faqSchema = z.faqs.length ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: z.faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
} : null;
const schema = faqSchema ? [serviceSchema, faqSchema] : [serviceSchema];
---
<Base title={z.metaTitle} titleTail={z.titleTail} description={z.metaDesc} schema={schema}>
  <section class="phero"><div class="wrap">
    <div class="crumbs"><a href="/">Inicio</a><span>›</span><a href="/areas-de-servicio/">Áreas</a><span>›</span>{z.nombre}</div>
    <span class="eyebrow">Área de servicio</span>
    <h1>{h1}</h1>
    <p class="lead">{z.hero}</p>
    <div class="cta-row"><a class="btn btn-amber" href={waLink(`Hola Multitainer, estoy en ${z.nombre} y quiero una cotización.`)} target="_blank" rel="noopener">Cotizar en {z.nombre} →</a></div>
  </div></section>

  <section class="pad"><div class="wrap">
    <div class="prose">
      {z.intro.map((p) => <p>{p}</p>)}
      <h2>Multitainer en {z.nombre}</h2>
      {z.local.map((p) => <p>{p}</p>)}
    </div>
  </div></section>

  <section class="pad" style="padding-top:0"><div class="wrap">
    <MapEmbed query={`${z.nombre}, Paraguay`} zoom={13} title={z.nombre} />
  </div></section>

  <section class="pad" style="padding-top:0"><div class="wrap">
    <div class="head" style="margin-bottom:24px"><span class="eyebrow">Lo que hacemos en {z.nombre}</span><h2>Nuestros servicios</h2></div>
    <div class="svc">
      {servicios.map((s) => (
        <a class="card" href={`/servicios/${s.slug}/`}>
          <div class="ic"><svg viewBox="0 0 24 24" set:html={s.icon}></svg></div>
          <h3>{s.nombre}</h3>
          <p>{s.hero}</p>
          <div class="arr">Ver {s.nombre.toLowerCase()} →</div>
        </a>
      ))}
    </div>
  </div></section>

  {z.faqs.length > 0 && (
    <section class="pad" style="padding-top:0"><div class="wrap">
      <div class="head"><span class="eyebrow">Preguntas frecuentes</span><h2>Trabajos en {z.nombre}</h2></div>
      <div class="faq">
        {z.faqs.map((f) => (<details><summary>{f.q}</summary><p>{f.a}</p></details>))}
      </div>
    </div></section>
  )}

  <section class="pad zones" style="padding-bottom:64px"><div class="wrap">
    <div class="head" style="margin-bottom:18px"><span class="eyebrow">Zonas vecinas</span><h2>También trabajamos cerca</h2></div>
    <div class="chips">
      {vecinas.map((v) => <a class="chip" href={`/areas-de-servicio/${v.slug}/`}>{v.nombre}</a>)}
      <a class="chip" href="/areas-de-servicio/">Ver todas las zonas</a>
    </div>
  </div></section>

  <section class="band">
    <span class="eyebrow">Hablemos hoy</span>
    <h2>Llegamos a {z.nombre}</h2>
    <p>Contanos qué necesitás y coordinamos la entrega e instalación.</p>
    <a class="btn btn-amber" href={waLink(`Hola Multitainer, estoy en ${z.nombre} y quiero una cotización.`)} target="_blank" rel="noopener">Escribir por WhatsApp →</a>
  </section>
</Base>

---
import { nav, waLink } from '../data/site';
---
<header class="nav">
  <div class="wrap nav-in">
    <a class="brand" href="/" aria-label="Multitainer inicio"><img src="/brand/mark.png" alt="" width="42" height="31" />MULTITAINER</a>
    <nav id="navmenu" aria-label="Principal">
      <ul>
        <li><a href="/">Inicio</a></li>
        {nav.map((n) => <li><a href={n.href}>{n.label}</a></li>)}
        <li><a class="btn btn-amber cta" href={waLink()} target="_blank" rel="noopener">Cotizar ahora</a></li>
      </ul>
    </nav>
    <button class="nav-toggle" aria-label="Abrir menú" aria-expanded="false" id="navtoggle">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"></path></svg>
    </button>
  </div>
</header>
<script is:inline>
  (function () {
    var t = document.getElementById('navtoggle'), m = document.getElementById('navmenu');
    if (!t || !m) return;
    t.addEventListener('click', function () {
      var open = m.classList.toggle('open');
      t.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    m.addEventListener('click', function (e) { if (e.target.tagName === 'A') m.classList.remove('open'); });
  })();
</script>

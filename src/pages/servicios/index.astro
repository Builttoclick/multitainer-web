---
import Base from '../../layouts/Base.astro';
import { site, waLink } from '../../data/site';
import { servicios } from '../../data/servicios';
import { zonas } from '../../data/zonas';

const desc = 'Servicios de Multitainer: alquiler de contenedores y módulos equipados, venta de contenedores marítimos y modificación / construcción modular llave en mano en Asunción y Gran Asunción.';
---
<Base title="Servicios" titleTail="alquiler, venta y modificación de contenedores en Gran Asunción" description={desc}>
  <section class="phero"><div class="wrap">
    <div class="crumbs"><a href="/">Inicio</a><span>›</span>Servicios</div>
    <span class="eyebrow">Qué hacemos</span>
    <h1>Todo el <b>contenedor</b>, en un solo lugar</h1>
    <p class="lead">Construimos, alquilamos, vendemos y transportamos contenedores marítimos. Con equipo técnico propio y logística propia, de la primera llamada a la entrega.</p>
    <div class="cta-row"><a class="btn btn-amber" href={waLink()} target="_blank" rel="noopener">Cotización en 24 h →</a></div>
  </div></section>

  <section class="pad"><div class="wrap">
    <div class="svc">
      {servicios.map((s, i) => (
        <a class={`card reveal${s.estrella ? ' is-star' : ''}`} style={`--d:${0.06 * i}s`} href={`/servicios/${s.slug}/`}>
          {s.estrella && <span class="star-badge">★ Estrella</span>}
          <div class="num">0{i + 1}</div>
          <div class="ic"><svg viewBox="0 0 24 24" set:html={s.icon}></svg></div>
          <h3>{s.nombre}</h3>
          <p>{s.hero}</p>
          <div class="arr">Ver {s.nombre.toLowerCase()} →</div>
        </a>
      ))}
    </div>
  </div></section>

  <section class="pad zones" style="padding-top:0;padding-bottom:64px"><div class="wrap">
    <div class="head" style="margin-bottom:18px">
      <span class="eyebrow">Dónde trabajamos</span>
      <h2>En todo el Gran Asunción</h2>
    </div>
    <div class="chips">
      {zonas.map((z) => <a class="chip" href={`/areas-de-servicio/${z.slug}/`}>{z.nombre}</a>)}
    </div>
  </div></section>

  <section class="band">
    <span class="eyebrow">Hablemos hoy</span>
    <h2>¿No sabés cuál necesitás?</h2>
    <p>Contanos tu proyecto y te recomendamos la mejor opción, con precio y plazo.</p>
    <a class="btn btn-amber" href={waLink()} target="_blank" rel="noopener">Escribir por WhatsApp →</a>
  </section>
</Base>

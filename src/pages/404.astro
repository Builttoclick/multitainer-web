---
import Base from '../layouts/Base.astro';
import { waLink } from '../data/site';
---
<Base title="Página no encontrada" noindex={true}>
  <section class="phero" style="min-height:60vh;display:flex;align-items:center"><div class="wrap" style="text-align:center">
    <span class="eyebrow">Error 404</span>
    <h1 style="margin-top:12px">Esta página se <b>mudó</b> o no existe</h1>
    <p class="lead" style="margin:16px auto 0">No encontramos lo que buscabas. Volvé al inicio o escribinos y te ayudamos.</p>
    <div class="cta-row" style="justify-content:center;margin-top:28px">
      <a class="btn btn-amber" href="/">Volver al inicio</a>
      <a class="btn btn-ghost" href={waLink()} target="_blank" rel="noopener">Escribir por WhatsApp</a>
    </div>
  </div></section>
</Base>

---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { site, waLink } from '../../data/site';
import { zonas } from '../../data/zonas';

export async function getStaticPaths() {
  const proyectos = await getCollection('proyectos');
  return proyectos.map((p) => ({ params: { slug: p.id }, props: { p } }));
}
const { p } = Astro.props;
const d = p.data;
const { Content } = await render(p);

const CAT_LABEL: Record<string, string> = {
  vivienda: 'Vivienda', oficina: 'Oficina', obrador: 'Obrador', vestuario: 'Vestuario',
  showroom: 'Showroom', campamento: 'Campamento', evento: 'Evento', bano: 'Baño', 'dos-plantas': 'Dos plantas',
};
// link de vuelta a la zona si coincide con una de las 9
const zonaMatch = zonas.find((z) => z.nombre.toLowerCase() === (d.zona ?? '').toLowerCase());
---
<Base
  title={d.metaTitle ?? d.titulo}
  titleTail={`proyecto en contenedor · ${CAT_LABEL[d.categoria] ?? d.categoria}`}
  description={d.metaDescription ?? d.resumen}
  image={d.portada}
>
  <section class="phero"><div class="wrap">
    <div class="crumbs"><a href="/">Inicio</a><span>›</span><a href="/proyectos/">Proyectos</a><span>›</span>{d.titulo}</div>
    <span class="eyebrow">{d.cliente ? d.cliente : (CAT_LABEL[d.categoria] ?? d.categoria)}</span>
    <h1>{d.titulo}</h1>
    <p class="lead">{d.resumen}</p>
    <div class="chips" style="margin-top:18px">
      <span class="chip">{CAT_LABEL[d.categoria] ?? d.categoria}</span>
      {d.zona && <span class="chip">📍 {d.zona}</span>}
      {d.medida && <span class="chip">📦 {d.medida}</span>}
      {d.anio && <span class="chip">🗓 {d.anio}</span>}
      {d.estado && <span class="chip">{d.estado}</span>}
    </div>
  </div></section>

  {d.portada && (
    <section style="padding-top:32px"><div class="wrap">
      <img src={d.portada} alt={d.portada_alt ?? d.titulo} style="width:100%;border-radius:6px;border:1px solid var(--line)" loading="eager" />
    </div></section>
  )}

  <section class="pad"><div class="wrap">
    <div class="split">
      <div class="prose"><Content /></div>
      <div class="media">
        {d.destacados.length > 0 && (
          <>
            <div class="eyebrow" style="margin-bottom:14px">Lo que lo hace</div>
            <ul class="ulist">{d.destacados.map((x) => <li>{x}</li>)}</ul>
          </>
        )}
        <a class="btn btn-amber" style="margin-top:24px" href={waLink(`Hola Multitainer, vi el proyecto "${d.titulo}" y quiero algo parecido.`)} target="_blank" rel="noopener">Quiero algo así →</a>
      </div>
    </div>
  </div></section>

  {d.galeria.length > 0 && (
    <section class="pad" style="padding-top:0"><div class="wrap">
      <div class="head"><span class="eyebrow">Galería</span><h2>Más fotos del proyecto</h2></div>
      <div class="gal">
        {d.galeria.map((g) => (<a href={g.src}><img src={g.src} alt={g.alt ?? d.titulo} loading="lazy" /></a>))}
      </div>
    </div></section>
  )}

  {d.faqs.length > 0 && (
    <section class="pad" style="padding-top:0"><div class="wrap">
      <div class="head"><span class="eyebrow">Preguntas frecuentes</span><h2>Sobre este proyecto</h2></div>
      <div class="faq">
        {d.faqs.map((f) => (<details><summary>{f.pregunta}</summary><p>{f.respuesta}</p></details>))}
      </div>
    </div></section>
  )}

  <section class="pad zones" style="padding-bottom:64px"><div class="wrap">
    <div class="chips">
      <a class="chip" href="/servicios/modificacion/">Ver modificación a medida</a>
      {zonaMatch && <a class="chip" href={`/areas-de-servicio/${zonaMatch.slug}/`}>Contenedores en {zonaMatch.nombre}</a>}
      <a class="chip" href="/proyectos/">Ver todos los proyectos</a>
    </div>
  </div></section>

  <section class="band">
    <span class="eyebrow">Tu proyecto es el próximo</span>
    <h2>Construyamos el tuyo</h2>
    <p>Contanos qué necesitás y te cotizamos en 24 horas.</p>
    <a class="btn btn-amber" href={waLink()} target="_blank" rel="noopener">Escribir por WhatsApp →</a>
  </section>
</Base>

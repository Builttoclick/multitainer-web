---
// 1 segmento bajo /areas-de-servicio/: maneja las 9 zonas legacy de Gran Asunción
// y los hubs de departamento (silo nacional). Las ciudades nacionales (2 segmentos)
// viven en [zona]/[ciudad].astro. Slugs de zonas y departamentos son disjuntos.
import AreaCiudadLegacy from '../../components/AreaCiudadLegacy.astro';
import AreaDepto from '../../components/AreaDepto.astro';
import { zonas } from '../../data/zonas';
import { departamentos } from '../../data/departamentos';

export async function getStaticPaths() {
  const zs = zonas.map((z, i) => ({ params: { zona: z.slug }, props: { tipo: 'zona', z, i } }));
  const ds = departamentos.map((d) => ({ params: { zona: d.slug }, props: { tipo: 'depto', d } }));
  return [...zs, ...ds];
}

const p = Astro.props as any;
---
{p.tipo === 'depto' ? <AreaDepto d={p.d} /> : <AreaCiudadLegacy z={p.z} i={p.i} />}

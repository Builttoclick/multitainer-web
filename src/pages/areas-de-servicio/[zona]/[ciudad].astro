---
import Base from '../../../layouts/Base.astro';
import MapEmbed from '../../../components/MapEmbed.astro';
import { site, waLink } from '../../../data/site';
import { servicios } from '../../../data/servicios';
import { getDepartamento } from '../../../data/departamentos';
import { ciudades, getCiudad, ciudadesDe } from '../../../data/ciudades';

export async function getStaticPaths() {
  return ciudades.map((c) => ({
    params: { zona: c.departamentoSlug, ciudad: c.slug },
    props: { c },
  }));
}
const { c } = Astro.props;
const depto = getDepartamento(c.departamentoSlug);
const hermanas = ciudadesDe(c.departamentoSlug).filter((x) => x.slug !== c.slug);

const h1 = `Contenedores y construcción modular en ${c.nombre}`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Contenedores y módulos en ${c.nombre}`,
  description: c.metaDesc,
  provider: { '@id': `${site.url}/#multitainer` },
  areaServed: {
    '@type': 'City',
    name: c.nombre,
    ...(depto ? { containedInPlace: { '@type': 'AdministrativeArea', name: depto.nombre } } : {}),
  },
};
const faqSchema = c.faqs.length ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: c.faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
} : null;
const schema = faqSchema ? [serviceSchema, faqSchema] : [serviceSchema];
---
<Base title={c.metaTitle} titleTail={c.titleTail} description={c.metaDesc} schema={schema}>
  <section class="phero"><div class="wrap">
    <div class="crumbs">
      <a href="/">Inicio</a><span>›</span>
      <a href="/areas-de-servicio/">Áreas</a><span>›</span>
      {depto && <><a href={`/areas-de-servicio/${depto.slug}/`}>{depto.nombre}</a><span>›</span></>}
      {c.nombre}
    </div>
    <span class="eyebrow">Área de servicio</span>
    <h1>{h1}</h1>
    <p class="lead">{c.hero}</p>
    <div class="cta-row"><a class="btn btn-amber" href={waLink(`Hola Multitainer, estoy en ${c.nombre} y quiero una cotización.`)} target="_blank" rel="noopener">Cotizar en {c.nombre} →</a></div>
  </div></section>

  <section class="pad"><div class="wrap">
    <div class="prose">
      {c.intro.map((p) => <p>{p}</p>)}
    </div>
  </div></section>

  <section class="pad" style="padding-top:0"><div class="wrap">
    <div class="geo">
      <div class="geo-map"><MapEmbed query={c.mapQuery} zoom={c.mapZoom} title={c.nombre} /></div>
      <div class="geo-ficha">
        <span class="eyebrow">Dónde estamos</span>
        <h2>Entregamos en toda {c.nombre}</h2>
        <p>Cubrimos la ciudad de punta a punta, con entrega e instalación en obra. Algunos puntos de referencia de la zona:</p>
        <ul class="refs">{c.landmarks.map((l) => <li>{l}</li>)}</ul>
        <p class="muted">{c.nombre}{c.poblacion ? ` · ${c.poblacion} hab.` : ''} · {c.departamento}, Paraguay</p>
      </div>
    </div>
  </div></section>

  <section class="pad" style="padding-top:0"><div class="wrap">
    <div class="prose">
      <h2>Multitainer en {c.nombre}</h2>
      {c.local.map((p) => <p>{p}</p>)}
    </div>
  </div></section>

  <section class="pad" style="padding-top:0"><div class="wrap">
    <div class="head" style="margin-bottom:24px"><span class="eyebrow">Lo que hacemos en {c.nombre}</span><h2>Nuestros servicios</h2></div>
    <div class="svc">
      {servicios.map((s) => (
        <a class="card" href={`/servicios/${s.slug}/`}>
          <div class="ic"><svg viewBox="0 0 24 24" set:html={s.icon}></svg></div>
          <h3>{s.nombre}</h3>
          <p>{s.hero}</p>
          <div class="arr">Ver {s.nombre.toLowerCase()} →</div>
        </a>
      ))}
    </div>
  </div></section>

  {c.faqs.length > 0 && (
    <section class="pad" style="padding-top:0"><div class="wrap">
      <div class="head"><span class="eyebrow">Preguntas frecuentes</span><h2>Trabajos en {c.nombre}</h2></div>
      <div class="faq">
        {c.faqs.map((f) => (<details><summary>{f.q}</summary><p>{f.a}</p></details>))}
      </div>
    </div></section>
  )}

  <section class="pad zones" style="padding-bottom:64px"><div class="wrap">
    <div class="head" style="margin-bottom:18px"><span class="eyebrow">En el mismo departamento</span><h2>También trabajamos cerca</h2></div>
    <div class="chips">
      {hermanas.map((v) => <a class="chip" href={`/areas-de-servicio/${v.departamentoSlug}/${v.slug}/`}>{v.nombre}</a>)}
      {depto && <a class="chip" href={`/areas-de-servicio/${depto.slug}/`}>Ver todo {depto.nombre}</a>}
    </div>
  </div></section>

  <section class="band">
    <span class="eyebrow">Hablemos hoy</span>
    <h2>Llegamos a {c.nombre}</h2>
    <p>Contanos qué necesitás y coordinamos la entrega e instalación.</p>
    <a class="btn btn-amber" href={waLink(`Hola Multitainer, estoy en ${c.nombre} y quiero una cotización.`)} target="_blank" rel="noopener">Escribir por WhatsApp →</a>
  </section>
</Base>

<style>
  .geo { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 28px; align-items: start; }
  .geo-ficha .eyebrow { margin-bottom: 8px; display: inline-block; }
  .geo-ficha h2 { margin: 0 0 10px; }
  .refs { margin: 12px 0 16px; padding-left: 18px; }
  .refs li { margin: 4px 0; }
  .muted { opacity: 0.6; font-size: 14px; }
  @media (max-width: 820px) { .geo { grid-template-columns: 1fr; } }
</style>

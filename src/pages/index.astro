---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { site, waLink, team, equipoTecnico } from '../data/site';
import { servicios } from '../data/servicios';
import { zonas } from '../data/zonas';

// Proyectos para la galería (por orden)
const todos = (await getCollection('proyectos')).sort((a, b) => (a.data.orden ?? 0) - (b.data.orden ?? 0));
const galeria = todos.slice(0, 6);
const layout = ['big', '', '', 'wide', '', ''];

// Ticker industrial
const ticker = ['Oficinas', 'Obradores', 'Vestuarios', 'Showrooms', 'Baños', 'Campamentos', 'Depósitos', 'Edificios de 2 plantas', "Contenedores 20'", "Contenedores 40'", 'Llave en mano'];

// Tipos de espacios (use-cases)
const usos = [
  { t: 'Casas', img: 'exterior-edificio-modular.jpg', href: '/servicios/modificacion/' },
  { t: 'Oficinas', img: 'int-oficina-moderno.jpg', href: '/servicios/modificacion/' },
  { t: 'Obradores', img: 'exterior-obrador.jpg', href: '/servicios/modificacion/' },
  { t: 'Vestuarios', img: 'vestuario-deportivo.jpg', href: '/servicios/modificacion/' },
  { t: 'Showrooms', img: '4pets-showroom.jpg', href: '/servicios/modificacion/' },
  { t: 'Baños', img: 'bano-blindex.jpg', href: '/servicios/modificacion/' },
  { t: 'Depósitos', img: 'exterior-modulo-oficina.jpg', href: '/servicios/venta/' },
  { t: 'Dos plantas', img: 'exterior-dos-plantas.jpg', href: '/servicios/modificacion/' },
];

// Proceso
const pasos = [
  { n: '1', t: 'Contás tu proyecto', d: 'Nos decís qué necesitás por WhatsApp. Te asesoramos sobre la mejor opción.' },
  { n: '2', t: 'Cotizamos en 24 h', d: 'Te enviamos una propuesta con precio y plazo, sin compromiso.' },
  { n: '3', t: 'Fabricamos en planta', d: 'Construimos tu módulo en nuestra planta de Mariano Roque Alonso.' },
  { n: '4', t: 'Entregamos e instalamos', d: 'Llevamos la unidad a tu predio y la dejamos lista para usar.' },
];

// Por qué Multitainer
const porque = [
  { ic: '<path d="M3 21h18"/><path d="M5 21V8l7-5 7 5v13"/>', t: 'Planta propia', d: 'Fabricamos en Mariano Roque Alonso, no tercerizamos.' },
  { ic: '<path d="M20 6 9 17l-5-5"/>', t: 'Llave en mano', d: 'Diseño, obra y entrega: te lo dejamos listo para usar.' },
  { ic: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>', t: 'Cotización en 24 h', d: 'Respondemos rápido, con precio y plazo claros.' },
  { ic: '<rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 12h18M12 3v18"/>', t: 'Estructura reforzada', d: 'Unimos y apilamos contenedores hasta en dos plantas.' },
  { ic: '<path d="M12 2 4 6v6c0 5 3.4 8 8 10 4.6-2 8-5 8-10V6z"/>', t: '4 Pets · CONMEBOL', d: 'Marcas e instituciones ya confiaron en nosotros.' },
  { ic: '<circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 8 12 8 12s8-6.6 8-12a8 8 0 0 0-8-8Z"/>', t: 'Todo el Gran Asunción', d: 'Entrega e instalación en las 9 zonas.' },
];

const desc = 'Multitainer construye con contenedores marítimos en Asunción y Gran Asunción: oficinas, obradores, vestuarios y showrooms llave en mano, más alquiler y venta de contenedores. Cotización en 24 horas.';
---
<Base description={desc}>
  <div class="scrollbar" id="sbar" aria-hidden="true"></div>

  <!-- HERO -->
  <section class="hero">
    <img class="bg" src="/fotos/hero-oficina-portuaria.jpg" alt="Oficinas en contenedores construidas por Multitainer" fetchpriority="high" />
    <div class="scrim"></div><div class="scrim2"></div><div class="grid-ov" aria-hidden="true"></div><div class="stripe"></div>
    <div class="wrap"><div class="inner">
      <span class="eyebrow reveal">Construcción modular en contenedores · Paraguay</span>
      <h1 class="reveal" style="--d:.08s">Construimos con <b>contenedores</b></h1>
      <p class="reveal" style="--d:.16s">Oficinas, obradores y espacios modulares llave en mano. Alquiler, venta y modificación de contenedores en Asunción y todo el Gran Asunción.</p>
      <div class="cta-row reveal" style="--d:.24s">
        <a class="btn btn-amber" href={waLink()} target="_blank" rel="noopener">Cotización en 24 h →</a>
        <a class="btn btn-ghost" href="/proyectos/">Ver proyectos</a>
      </div>
    </div></div>
  </section>

  <!-- STATS (con conteo animado) -->
  <div class="stats"><div class="wrap">
    <div class="stat"><div class="n"><span data-count-to="24">0</span> h</div><div class="l">Cotización entregada</div></div>
    <div class="stat"><div class="n">Llave en mano</div><div class="l">Diseño + obra + entrega</div></div>
    <div class="stat"><div class="n">20' y 40'</div><div class="l">Contenedores marítimos</div></div>
    <div class="stat"><div class="n"><span data-count-to="9">0</span> zonas</div><div class="l">Gran Asunción</div></div>
  </div></div>

  <!-- TICKER -->
  <div class="ticker" aria-hidden="true">
    <div class="tick-track">
      {[...ticker, ...ticker].map((t) => (<><span>{t}</span><span class="sep">◆</span></>))}
    </div>
  </div>

  <!-- SERVICIOS -->
  <section class="pad" id="servicios"><div class="wrap">
    <div class="head reveal">
      <span class="eyebrow">Qué hacemos</span>
      <h2>Todo el contenedor, en un solo lugar</h2>
      <p>Construimos, alquilamos, vendemos y transportamos. Con equipo técnico propio, de la primera llamada a la entrega.</p>
    </div>
    <div class="svc">
      {servicios.map((s, i) => (
        <a class={`card spot reveal${s.estrella ? ' is-star' : ''}`} style={`--d:${0.06 * i}s`} href={`/servicios/${s.slug}/`}>
          {s.estrella && <span class="star-badge">★ Estrella</span>}
          <div class="num">0{i + 1}</div>
          <div class="ic"><svg viewBox="0 0 24 24" set:html={s.icon}></svg></div>
          <h3>{s.nombre}</h3>
          <p>{s.hero}</p>
          <div class="arr">Ver {s.nombre.toLowerCase()} →</div>
        </a>
      ))}
    </div>
  </div></section>

  <!-- ANTES / DESPUÉS (slider) -->
  <section class="pad ba-sec"><div class="wrap">
    <div class="head reveal">
      <span class="eyebrow">El cambio</span>
      <h2>Por fuera, un contenedor.<br>Por dentro, tu espacio.</h2>
      <p>Arrastrá para ver la transformación. El mismo módulo, de la chapa cruda al ambiente terminado.</p>
    </div>
    <div class="ba reveal" id="ba" style="--pos:50%">
      <img class="ba-after" src="/fotos/int-porcelanato-led.jpg" alt="Interior de oficina en contenedor terminado con porcelanato y LED" loading="lazy" />
      <img class="ba-before" src="/fotos/exterior-modulo-oficina.jpg" alt="Módulo de contenedor por fuera" loading="lazy" />
      <span class="ba-tag ba-l">Por fuera</span>
      <span class="ba-tag ba-r">Por dentro</span>
      <div class="ba-handle"><span></span></div>
      <input class="ba-range" type="range" min="0" max="100" value="50" aria-label="Comparar antes y después" />
    </div>
  </div></section>

  <!-- TIPOS DE ESPACIOS -->
  <section class="pad" style="padding-top:0"><div class="wrap">
    <div class="head reveal">
      <span class="eyebrow">Qué construimos</span>
      <h2>Un contenedor, mil espacios</h2>
      <p>Estos son algunos de los espacios que entregamos. Si lo imaginás, lo construimos.</p>
    </div>
    <div class="uses">
      {usos.map((u, i) => (
        <a class="use reveal" style={`--d:${0.04 * (i % 4)}s`} href={u.href}>
          <img src={`/fotos/${u.img}`} alt={`${u.t} en contenedor — Multitainer`} loading="lazy" />
          <span class="use-ov"></span>
          <span class="use-t">{u.t}</span>
        </a>
      ))}
    </div>
  </div></section>

  <!-- PROCESO -->
  <section class="pad proc-sec"><div class="wrap">
    <div class="head center reveal">
      <span class="eyebrow">Cómo trabajamos</span>
      <h2>De la idea a la obra, en 4 pasos</h2>
    </div>
    <div class="proc">
      <div class="proc-line" aria-hidden="true"></div>
      {pasos.map((p, i) => (
        <div class="proc-step reveal" style={`--d:${0.12 * i}s`}>
          <div class="proc-num">{p.n}</div>
          <h3>{p.t}</h3>
          <p>{p.d}</p>
        </div>
      ))}
    </div>
  </div></section>

  <!-- PROYECTOS -->
  <section class="pad" id="proyectos" style="padding-top:0"><div class="wrap">
    <div class="head reveal">
      <span class="eyebrow">Proyectos</span>
      <h2>Obras que ya entregamos</h2>
    </div>
    <div class="gal">
      {galeria.map((p, i) => (
        <a class={`reveal ${layout[i] ?? ''}`} style={`--d:${0.05 * i}s`} href={`/proyectos/${p.id}/`}>
          <img src={p.data.portada} alt={p.data.portada_alt ?? p.data.titulo} loading={i === 0 ? 'eager' : 'lazy'} />
          <span class="tag">{p.data.cliente ?? p.data.titulo}</span>
        </a>
      ))}
    </div>
    <div class="trust reveal"><b>Confían en nosotros:</b> 4 Pets · CONMEBOL · obras y empresas de todo el país.</div>
    <div style="margin-top:30px"><a class="btn btn-ghost" href="/proyectos/">Ver todos los proyectos</a></div>
  </div></section>

  <!-- POR QUÉ MULTITAINER -->
  <section class="pad why-sec"><div class="wrap">
    <div class="head reveal">
      <span class="eyebrow">Por qué Multitainer</span>
      <h2>La fábrica detrás de tu espacio</h2>
    </div>
    <div class="why">
      {porque.map((w, i) => (
        <div class="why-card reveal" style={`--d:${0.05 * (i % 3)}s`}>
          <div class="why-ic"><svg viewBox="0 0 24 24" set:html={w.ic}></svg></div>
          <h3>{w.t}</h3>
          <p>{w.d}</p>
        </div>
      ))}
    </div>
  </div></section>

  <!-- EQUIPO -->
  <section class="pad equipo-sec" id="equipo"><div class="wrap">
    <div class="head center reveal">
      <span class="eyebrow">Nuestro equipo</span>
      <h2>Quién va a hacer tu proyecto</h2>
      <p>No subcontratamos: {equipoTecnico}, todo bajo el mismo techo en nuestra planta de Mariano Roque Alonso.</p>
    </div>
    <div class="team">
      {team.map((m, i) => (
        <div class="team-card reveal" style={`--d:${0.05 * i}s`}>
          <div class="team-av">{m.ini}</div>
          <h4>{m.nombre}</h4>
          <div class="rol">{m.rol}</div>
        </div>
      ))}
    </div>
  </div></section>

  <!-- ZONAS -->
  <section class="pad zones" id="zonas"><div class="wrap">
    <div class="head reveal" style="margin-bottom:18px">
      <span class="eyebrow">Áreas de servicio</span>
      <h2>Asunción y todo el Gran Asunción</h2>
      <p>Con base en Mariano Roque Alonso, llegamos a las 9 zonas del Gran Asunción.</p>
    </div>
    <div class="chips reveal">
      {zonas.map((z) => <a class="chip" href={`/areas-de-servicio/${z.slug}/`}>{z.nombre}</a>)}
    </div>
  </div></section>

  <!-- VISITÁ LA PLANTA -->
  <section class="pad plant-sec"><div class="wrap">
    <div class="plant">
      <div class="plant-copy reveal">
        <span class="eyebrow">Dónde estamos</span>
        <h2>Visitá nuestra planta</h2>
        <p>Estamos en Gral. Patricio Escobar casi Gral. J. M. Bruguez, Mariano Roque Alonso. Vení a ver contenedores y proyectos terminados.</p>
        <div class="plant-nap">
          <div><b>Dirección</b><br>{site.addressFull}</div>
          <div><b>Horario</b><br>{site.hours}</div>
          <div><b>WhatsApp</b><br><a href={site.whatsapp} target="_blank" rel="noopener">{site.whatsappLabel}</a></div>
        </div>
        <div class="cta-row" style="margin-top:24px"><a class="btn btn-amber" href={waLink()} target="_blank" rel="noopener">Coordinar una visita →</a></div>
      </div>
      <div class="plant-map reveal" style="--d:.1s">
        {site.gbpEmbed
          ? <iframe src={site.gbpEmbed} loading="lazy" title="Ubicación de Multitainer en Google Maps" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
          : <div class="map-ph">Mapa de Google Business</div>}
      </div>
    </div>
  </div></section>

  <!-- CTA -->
  <section class="band" id="cta">
    <span class="eyebrow">Hablemos hoy</span>
    <h2>Te cotizamos en 24 horas</h2>
    <p>Contanos qué necesitás y te enviamos una propuesta con precio y plazo.</p>
    <a class="btn btn-amber" href={waLink()} target="_blank" rel="noopener">Escribir por WhatsApp →</a>
  </section>
</Base>

<style>
  /* ===== HERO ===== */
  .hero { position: relative; min-height: 90vh; display: flex; align-items: flex-end; overflow: hidden; }
  .hero img.bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; filter: grayscale(.15) contrast(1.05); transform: scale(1.06); animation: heroZoom 18s ease-out forwards; }
  @keyframes heroZoom { to { transform: scale(1); } }
  .hero .scrim { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(12,13,16,.6) 0%, rgba(12,13,16,.32) 38%, rgba(12,13,16,.96) 100%); }
  .hero .scrim2 { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(12,13,16,.78), transparent 60%); }
  .hero .grid-ov { position: absolute; inset: 0; background-image: linear-gradient(rgba(237,180,63,.05) 1px, transparent 1px), linear-gradient(90deg, rgba(237,180,63,.05) 1px, transparent 1px); background-size: 48px 48px; mask: radial-gradient(120% 90% at 30% 100%, #000, transparent 75%); }
  .hero .stripe { position: absolute; left: 0; top: 0; bottom: 0; width: 8px; background: repeating-linear-gradient(45deg, var(--amber) 0 14px, #1a1205 14px 28px); opacity: .9; }
  .hero > .wrap { width: 100%; min-width: 0; position: relative; z-index: 2; }
  .hero .inner { padding: 0 0 66px; max-width: 800px; }
  .hero h1 { font-size: clamp(42px, 7vw, 88px); color: #fff; margin: 18px 0 0; text-shadow: 0 2px 30px rgba(0,0,0,.4); }
  .hero h1 b { color: var(--amber); }
  .hero p { font-size: clamp(16px, 1.7vw, 20px); color: #d6dae1; max-width: 560px; margin: 20px 0 30px; }

  /* ===== TICKER ===== */
  .ticker { overflow: hidden; background: var(--amber); border-top: 3px solid #1a1205; border-bottom: 3px solid #1a1205; }
  .tick-track { display: flex; align-items: center; gap: 22px; width: max-content; white-space: nowrap; animation: tick 34s linear infinite; padding: 11px 0; }
  .ticker:hover .tick-track { animation-play-state: paused; }
  .tick-track span { font-family: var(--h); font-weight: 800; text-transform: uppercase; letter-spacing: .04em; font-size: 15px; color: #1a1205; }
  .tick-track span.sep { font-size: 10px; opacity: .65; }
  @keyframes tick { to { transform: translateX(-50%); } }

  /* ===== SERVICE CARD SPOTLIGHT ===== */
  .svc .card.spot::after { content: ""; position: absolute; inset: 0; border-radius: 4px; background: radial-gradient(260px circle at var(--mx, 50%) var(--my, 50%), rgba(237,180,63,.14), transparent 55%); opacity: 0; transition: opacity .25s; pointer-events: none; z-index: 0; }
  .svc .card.spot:hover::after { opacity: 1; }
  .svc .card.spot > *:not(.star-badge) { position: relative; z-index: 1; }

  /* ===== ANTES / DESPUÉS ===== */
  .ba { position: relative; aspect-ratio: 16 / 10; border-radius: 6px; overflow: hidden; border: 1px solid var(--line); user-select: none; touch-action: pan-y; box-shadow: var(--shadow); }
  .ba img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; pointer-events: none; }
  .ba-before { clip-path: inset(0 calc(100% - var(--pos, 50%)) 0 0); }
  .ba-tag { position: absolute; top: 16px; z-index: 3; font-family: var(--h); font-weight: 800; text-transform: uppercase; font-size: 12px; letter-spacing: .08em; padding: 7px 13px; border-radius: 2px; background: rgba(12,13,16,.78); color: #fff; }
  .ba-tag.ba-l { left: 16px; border-left: 3px solid var(--mut); }
  .ba-tag.ba-r { right: 16px; border-left: 3px solid var(--amber); color: var(--amber); }
  .ba-handle { position: absolute; top: 0; bottom: 0; left: var(--pos, 50%); width: 3px; background: var(--amber); z-index: 4; transform: translateX(-50%); pointer-events: none; }
  .ba-handle span { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 46px; height: 46px; border-radius: 50%; background: var(--amber); display: flex; align-items: center; justify-content: center; box-shadow: 0 6px 20px rgba(0,0,0,.45); }
  .ba-handle span::before, .ba-handle span::after { content: ""; position: absolute; width: 0; height: 0; border-block: 6px solid transparent; }
  .ba-handle span::before { left: 9px; border-right: 8px solid #1a1205; }
  .ba-handle span::after { right: 9px; border-left: 8px solid #1a1205; }
  .ba-range { position: absolute; inset: 0; width: 100%; height: 100%; margin: 0; opacity: 0; cursor: ew-resize; z-index: 5; }

  /* ===== TIPOS DE ESPACIOS ===== */
  .uses { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
  .use { position: relative; aspect-ratio: 1; border-radius: 5px; overflow: hidden; display: block; border: 1px solid var(--line); }
  .use img { width: 100%; height: 100%; object-fit: cover; transition: transform .45s ease; filter: grayscale(.3) brightness(.7); }
  .use:hover img { transform: scale(1.08); filter: grayscale(0) brightness(.85); }
  .use-ov { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 40%, rgba(12,13,16,.85)); }
  .use-t { position: absolute; left: 14px; bottom: 13px; z-index: 2; font-family: var(--h); font-weight: 800; text-transform: uppercase; font-size: 15px; letter-spacing: .03em; color: #fff; }
  .use::before { content: ""; position: absolute; left: 0; bottom: 0; width: 100%; height: 3px; background: var(--amber); transform: scaleX(0); transform-origin: left; transition: transform .3s ease; z-index: 3; }
  .use:hover::before { transform: scaleX(1); }

  /* ===== PROCESO ===== */
  .proc-sec { background: var(--ink2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .proc { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; position: relative; }
  .proc-line { position: absolute; top: 27px; left: 8%; right: 8%; height: 2px; background: repeating-linear-gradient(90deg, var(--line2) 0 10px, transparent 10px 18px); }
  .proc-step { text-align: center; position: relative; }
  .proc-num { width: 54px; height: 54px; border-radius: 50%; margin: 0 auto 18px; display: flex; align-items: center; justify-content: center; font-family: var(--h); font-weight: 900; font-size: 22px; color: var(--amber); background: var(--ink); border: 2px solid var(--amber); position: relative; z-index: 1; }
  .proc-step h3 { font-size: 18px; color: #fff; margin-bottom: 8px; text-transform: none; letter-spacing: 0; }
  .proc-step p { color: var(--mut); font-size: 14.5px; max-width: 230px; margin: 0 auto; }

  /* ===== POR QUÉ ===== */
  .why { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .why-card { background: var(--ink2); border: 1px solid var(--line); border-radius: 5px; padding: 26px 24px; transition: .2s; }
  .why-card:hover { border-color: var(--amber); transform: translateY(-4px); }
  .why-ic { width: 38px; height: 38px; color: var(--amber); margin-bottom: 14px; }
  .why-ic svg { width: 100%; height: 100%; fill: none; stroke: currentColor; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
  .why-card h3 { font-size: 18px; color: #fff; margin-bottom: 7px; text-transform: none; letter-spacing: 0; }
  .why-card p { color: var(--mut); font-size: 14.5px; }

  /* ===== VISITÁ LA PLANTA ===== */
  .plant { display: grid; grid-template-columns: 1fr 1fr; gap: 44px; align-items: center; }
  .plant-copy h2 { font-size: clamp(28px, 4vw, 42px); color: #fff; margin: 14px 0 14px; }
  .plant-copy > p { color: var(--mut); font-size: 17px; max-width: 480px; }
  .plant-nap { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-top: 24px; }
  .plant-nap div { color: #c5cad3; font-size: 15px; line-height: 1.6; }
  .plant-nap b { font-family: var(--h); text-transform: uppercase; font-size: 12px; letter-spacing: .08em; color: var(--amber); }
  .plant-nap a:hover { color: var(--amber); }
  .plant-map iframe { width: 100%; height: 380px; border: 1px solid var(--line); border-radius: 6px; filter: grayscale(.2) invert(.92) hue-rotate(180deg) contrast(.9); }
  .map-ph { width: 100%; height: 380px; border: 1px dashed var(--line2); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: #5a6170; }

  /* ===== responsive ===== */
  @media (max-width: 900px) {
    .hero { min-height: 80vh; }
    .hero .inner { padding-bottom: 44px; }
    .cta-row .btn { flex: 1; justify-content: center; }
    .uses { grid-template-columns: repeat(2, 1fr); }
    .proc { grid-template-columns: 1fr 1fr; gap: 30px; }
    .proc-line { display: none; }
    .why { grid-template-columns: 1fr; }
    .plant { grid-template-columns: 1fr; gap: 26px; }
    .plant-map iframe { height: 300px; }
  }
  @media (max-width: 560px) {
    .uses { grid-template-columns: 1fr 1fr; }
    .proc { grid-template-columns: 1fr; }
    .plant-nap { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero img.bg { animation: none; transform: none; }
    .tick-track { animation: none; }
  }
</style>

<script is:inline>
  (function () {
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Count-up
    function countUp(el) {
      var to = parseInt(el.getAttribute('data-count-to'), 10) || 0, dur = 1100, t0 = null;
      function step(ts) { if (!t0) t0 = ts; var p = Math.min((ts - t0) / dur, 1); el.textContent = Math.round(p * to); if (p < 1) requestAnimationFrame(step); }
      requestAnimationFrame(step);
    }
    var counters = document.querySelectorAll('[data-count-to]');
    if (reduce) { counters.forEach(function (el) { el.textContent = el.getAttribute('data-count-to'); }); }
    else {
      var co = new IntersectionObserver(function (es) { es.forEach(function (e) { if (e.isIntersecting) { countUp(e.target); co.unobserve(e.target); } }); }, { threshold: .6 });
      counters.forEach(function (el) { co.observe(el); });
    }

    // Spotlight en service cards
    if (!reduce && window.matchMedia('(hover:hover)').matches) {
      document.querySelectorAll('.card.spot').forEach(function (c) {
        c.addEventListener('pointermove', function (e) {
          var r = c.getBoundingClientRect();
          c.style.setProperty('--mx', (e.clientX - r.left) + 'px');
          c.style.setProperty('--my', (e.clientY - r.top) + 'px');
        });
      });
    }

    // Antes / Después
    var ba = document.getElementById('ba');
    if (ba) {
      var range = ba.querySelector('.ba-range');
      function set(v) { ba.style.setProperty('--pos', v + '%'); }
      range.addEventListener('input', function () { set(range.value); });
    }
  })();
</script>

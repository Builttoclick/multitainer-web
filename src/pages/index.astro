---
import Base from '../layouts/Base.astro';
import { site, waLink, team, equipoTecnico } from '../data/site';
import { servicios } from '../data/servicios';
import { zonas } from '../data/zonas';
import { obras } from '../data/obras';

// Reel de anuncios (videos servidos desde Cloudflare R2)
const R2 = 'https://media.multitainer.com.py';
const reels = [
  { src: `${R2}/anuncios/anuncio-3.mp4`, poster: `${R2}/anuncios/poster-3.webp`, tag: 'Oficina en un contenedor', sub: '“Vamos a ser sinceros…”', dur: '0:47' },
  { src: `${R2}/anuncios/anuncio-2.mp4`, poster: `${R2}/anuncios/poster-2.webp`, tag: 'Mentalidad alfa', sub: 'La versión animada', dur: '1:13' },
];

// Ticker industrial
const ticker = ['Oficinas', 'Obradores', 'Vestuarios', 'Showrooms', 'Baños', 'Campamentos', 'Depósitos', 'Edificios de 2 plantas', "Contenedores 20'", "Contenedores 40'", 'Llave en mano'];

// Tipos de espacios (use-cases)
const usos = [
  { t: 'Casas', img: 'exterior-edificio-modular.jpg', href: '/servicios/modificacion/' },
  { t: 'Oficinas', img: 'int-oficina-moderno.jpg', href: '/servicios/modificacion/' },
  { t: 'Obradores', img: 'exterior-obrador.jpg', href: '/servicios/modificacion/' },
  { t: 'Vestuarios', img: 'vestuario-deportivo.jpg', href: '/servicios/modificacion/' },
  { t: 'Showrooms', img: '4pets-showroom.jpg', href: '/servicios/modificacion/' },
  { t: 'Baños', img: 'bano-blindex.jpg', href: '/servicios/modificacion/' },
  { t: 'Depósitos', img: 'exterior-modulo-oficina.jpg', href: '/servicios/venta/' },
  { t: 'Dos plantas', img: 'exterior-dos-plantas.jpg', href: '/servicios/modificacion/' },
];

// Proceso
const pasos = [
  { n: '1', t: 'Contás tu proyecto', d: 'Nos decís qué necesitás por WhatsApp. Te asesoramos sobre la mejor opción.' },
  { n: '2', t: 'Cotizamos en 24 h', d: 'Te enviamos una propuesta con precio y plazo, sin compromiso.' },
  { n: '3', t: 'Fabricamos en planta', d: 'Construimos tu módulo en nuestra planta de Mariano Roque Alonso.' },
  { n: '4', t: 'Entregamos e instalamos', d: 'Llevamos la unidad a tu predio y la dejamos lista para usar.' },
];

// Por qué Multitainer
const porque = [
  { ic: '<path d="M3 21h18"/><path d="M5 21V8l7-5 7 5v13"/>', t: 'Planta propia', d: 'Fabricamos en Mariano Roque Alonso, no tercerizamos.' },
  { ic: '<path d="M20 6 9 17l-5-5"/>', t: 'Llave en mano', d: 'Diseño, obra y entrega: te lo dejamos listo para usar.' },
  { ic: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>', t: 'Cotización en 24 h', d: 'Respondemos rápido, con precio y plazo claros.' },
  { ic: '<rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 12h18M12 3v18"/>', t: 'Estructura reforzada', d: 'Unimos y apilamos contenedores hasta en dos plantas.' },
  { ic: '<path d="M12 2 4 6v6c0 5 3.4 8 8 10 4.6-2 8-5 8-10V6z"/>', t: '4 Pets · CONMEBOL', d: 'Marcas e instituciones ya confiaron en nosotros.' },
  { ic: '<circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 8 12 8 12s8-6.6 8-12a8 8 0 0 0-8-8Z"/>', t: 'Todo el Gran Asunción', d: 'Entrega e instalación en las 9 zonas.' },
];

const heroWords = ['Construimos', 'con', 'contenedores'];
const desc = 'Multitainer construye con contenedores marítimos en Asunción y Gran Asunción: oficinas, obradores, vestuarios y showrooms llave en mano, más alquiler y venta de contenedores. Cotización en 24 horas.';
---
<Base description={desc} image="/fotos/obras/schwartzmann-pileta.webp">
  <div class="scrollbar" id="sbar" aria-hidden="true"></div>

  <!-- HERO -->
  <section class="hero">
    <div class="bgwrap" aria-hidden="true"><img class="bg" data-parallax="0.12" src="/fotos/obras/schwartzmann-pileta.webp" alt="Vivienda de lujo construida con contenedores marítimos por Multitainer, al atardecer con piscina" fetchpriority="high" width="1280" height="928" /></div>
    <div class="scrim"></div><div class="scrim2"></div><div class="grid-ov" aria-hidden="true"></div><div class="stripe"></div>
    <div class="wrap"><div class="inner">
      <span class="eyebrow hw" style="--i:0">Construcción modular en contenedores · Paraguay</span>
      <h1 class="hwrap">{heroWords.map((w, i) => (
        <span class="hw word" style={`--i:${i + 1}`}>{i === heroWords.length - 1 ? <b>{w}</b> : w}{' '}</span>
      ))}</h1>
      <p class="hw" style="--i:4">Oficinas, obradores y espacios modulares llave en mano. Alquiler, venta y modificación de contenedores en Asunción y todo el Gran Asunción.</p>
      <div class="cta-row hw" style="--i:5">
        <a class="btn btn-amber mag" href={waLink()} target="_blank" rel="noopener">Cotización en 24 h →</a>
        <a class="btn btn-ghost mag" href="#obras">Ver obras</a>
      </div>
    </div></div>
    <div class="hero-down" aria-hidden="true"><span></span></div>
  </section>

  <!-- STATS (con conteo animado) -->
  <div class="stats"><div class="wrap">
    <div class="stat"><div class="n"><span data-count-to="24">0</span> h</div><div class="l">Cotización entregada</div></div>
    <div class="stat"><div class="n">Llave en mano</div><div class="l">Diseño + obra + entrega</div></div>
    <div class="stat"><div class="n">20' y 40'</div><div class="l">Contenedores marítimos</div></div>
    <div class="stat"><div class="n"><span data-count-to="9">0</span> zonas</div><div class="l">Gran Asunción</div></div>
  </div></div>

  <!-- TICKER -->
  <div class="ticker" aria-hidden="true">
    <div class="tick-track">
      {[...ticker, ...ticker].map((t) => (<><span>{t}</span><span class="sep">◆</span></>))}
    </div>
  </div>

  <!-- SERVICIOS -->
  <section class="pad" id="servicios"><div class="wrap">
    <div class="head reveal">
      <span class="eyebrow">Qué hacemos</span>
      <h2>Todo el contenedor, en un solo lugar</h2>
      <p>Construimos, alquilamos, vendemos y transportamos. Con equipo técnico propio, de la primera llamada a la entrega.</p>
    </div>
    <div class="svc">
      {servicios.map((s, i) => (
        <a class={`card reveal${s.estrella ? ' is-star' : ''}`} style={`--d:${0.06 * i}s`} href={`/servicios/${s.slug}/`}>
          {s.estrella && <span class="star-badge">★ Estrella</span>}
          <div class="num">0{i + 1}</div>
          <div class="ic"><svg viewBox="0 0 24 24" set:html={s.icon}></svg></div>
          <h3>{s.nombre}</h3>
          <p>{s.hero}</p>
          <div class="arr">Ver {s.nombre.toLowerCase()} →</div>
        </a>
      ))}
    </div>
  </div></section>

  <!-- OBRAS (galería + lightbox) -->
  <section class="pad" id="obras" style="padding-top:0"><div class="wrap">
    <div class="head reveal">
      <span class="eyebrow">Obras reales</span>
      <h2>Lo que entregamos, por dentro y por fuera</h2>
      <p>Viviendas, oficinas y espacios premium que construimos con contenedores. Tocá cualquier foto para verla en grande.</p>
    </div>
    <div class="obras" id="gal">
      {obras.map((o, i) => (
        <button
          class={`obra reveal bup ${o.span}`}
          style={`--d:${0.04 * (i % 4)}s; background-image:url(${o.lqip})`}
          data-i={i} data-full={o.src} data-label={o.label}
          aria-label={`Ampliar foto: ${o.label}`}>
          <img class="media" src={o.thumb} alt={`${o.label} — obra de Multitainer en contenedor`} loading="lazy" decoding="async" width={o.w} height={o.h} onload="this.closest('.bup').classList.add('is-loaded')" />
          <span class="ov"></span>
          <span class="cat">{o.cat}</span>
          <span class="lbl">{o.label}</span>
          <span class="exp" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg></span>
        </button>
      ))}
    </div>
    <div class="trust reveal"><b>Confían en nosotros:</b> 4 Pets · CONMEBOL · obras y empresas de todo el país.</div>
  </div></section>

  <!-- REEL (anuncios en video) -->
  <section class="pad reel-sec"><div class="wrap">
    <div class="head center reveal">
      <span class="eyebrow">Multitainer en acción</span>
      <h2>Mirá de qué hablamos</h2>
      <p>El contenedor no es lo que pensás. Dale play.</p>
    </div>
    <div class="reels reveal">
      {reels.map((r) => (
        <div class="reel" data-reel>
          <video preload="none" playsinline poster={r.poster} src={r.src}></video>
          <span class="reel-grad" aria-hidden="true"></span>
          <button class="reel-play" aria-label={`Reproducir: ${r.tag}`}>
            <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          </button>
          <span class="reel-dur">{r.dur}</span>
          <div class="reel-meta">
            <span class="reel-tag">{r.tag}</span>
            <span class="reel-sub">{r.sub}</span>
          </div>
        </div>
      ))}
    </div>
  </div></section>

  <!-- TIPOS DE ESPACIOS -->
  <section class="pad"><div class="wrap">
    <div class="head reveal">
      <span class="eyebrow">Qué construimos</span>
      <h2>Un contenedor, mil espacios</h2>
      <p>Estos son algunos de los espacios que entregamos. Si lo imaginás, lo construimos.</p>
    </div>
    <div class="uses">
      {usos.map((u, i) => (
        <a class="use reveal" style={`--d:${0.04 * (i % 4)}s`} href={u.href}>
          <img src={`/fotos/${u.img}`} alt={`${u.t} en contenedor — Multitainer`} loading="lazy" />
          <span class="use-ov"></span>
          <span class="use-t">{u.t}</span>
        </a>
      ))}
    </div>
  </div></section>

  <!-- PROCESO -->
  <section class="pad proc-sec"><div class="wrap">
    <div class="head center reveal">
      <span class="eyebrow">Cómo trabajamos</span>
      <h2>De la idea a la obra, en 4 pasos</h2>
    </div>
    <div class="proc" id="proc">
      <div class="proc-line" aria-hidden="true"></div>
      {pasos.map((p, i) => (
        <div class="proc-step reveal" style={`--d:${0.12 * i}s`}>
          <div class="proc-num">{p.n}</div>
          <h3>{p.t}</h3>
          <p>{p.d}</p>
        </div>
      ))}
    </div>
  </div></section>

  <!-- POR QUÉ MULTITAINER -->
  <section class="pad why-sec"><div class="wrap">
    <div class="head reveal">
      <span class="eyebrow">Por qué Multitainer</span>
      <h2>La fábrica detrás de tu espacio</h2>
    </div>
    <div class="why">
      {porque.map((w, i) => (
        <div class="why-card reveal" style={`--d:${0.05 * (i % 3)}s`}>
          <div class="why-ic"><svg viewBox="0 0 24 24" set:html={w.ic}></svg></div>
          <h3>{w.t}</h3>
          <p>{w.d}</p>
        </div>
      ))}
    </div>
  </div></section>

  <!-- EQUIPO -->
  <section class="pad equipo-sec" id="equipo"><div class="wrap">
    <div class="head center reveal">
      <span class="eyebrow">Nuestro equipo</span>
      <h2>Quién va a hacer tu proyecto</h2>
      <p>No subcontratamos: {equipoTecnico}, todo bajo el mismo techo en nuestra planta de Mariano Roque Alonso.</p>
    </div>
    <div class="team">
      {team.map((m, i) => (
        <div class="team-card reveal" style={`--d:${0.05 * i}s`}>
          {m.foto
            ? <div class="team-av"><img src={m.foto} alt={`${m.nombre} — ${m.rol}, Multitainer`} loading="lazy" width="66" height="66" /></div>
            : <div class="team-av">{m.ini}</div>}
          <h4>{m.nombre}</h4>
          <div class="rol">{m.rol}</div>
        </div>
      ))}
    </div>
  </div></section>

  <!-- ZONAS -->
  <section class="pad zones" id="zonas"><div class="wrap">
    <div class="head reveal" style="margin-bottom:18px">
      <span class="eyebrow">Áreas de servicio</span>
      <h2>Asunción y todo el Gran Asunción</h2>
      <p>Con base en Mariano Roque Alonso, llegamos a las 9 zonas del Gran Asunción.</p>
    </div>
    <div class="chips reveal">
      {zonas.map((z) => <a class="chip" href={`/areas-de-servicio/${z.slug}/`}>{z.nombre}</a>)}
    </div>
  </div></section>

  <!-- VISITÁ LA PLANTA -->
  <section class="pad plant-sec"><div class="wrap">
    <div class="plant">
      <div class="plant-copy reveal">
        <span class="eyebrow">Dónde estamos</span>
        <h2>Visitá nuestra planta</h2>
        <p>Estamos en Gral. Patricio Escobar casi Gral. J. M. Bruguez, Mariano Roque Alonso. Vení a ver contenedores y proyectos terminados.</p>
        <div class="plant-nap">
          <div><b>Dirección</b><br>{site.addressFull}</div>
          <div><b>Horario</b><br>{site.hours}</div>
          <div><b>WhatsApp</b><br><a href={site.whatsapp} target="_blank" rel="noopener">{site.whatsappLabel}</a></div>
        </div>
        <div class="cta-row" style="margin-top:24px"><a class="btn btn-amber mag" href={waLink()} target="_blank" rel="noopener">Coordinar una visita →</a></div>
      </div>
      <div class="plant-map reveal" style="--d:.1s">
        {site.gbpEmbed
          ? <iframe src={site.gbpEmbed} loading="lazy" title="Ubicación de Multitainer en Google Maps" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
          : <div class="map-ph">Mapa de Google Business</div>}
      </div>
    </div>
  </div></section>

  <!-- CTA -->
  <section class="band" id="cta">
    <span class="eyebrow">Hablemos hoy</span>
    <h2>Te cotizamos en 24 horas</h2>
    <p>Contanos qué necesitás y te enviamos una propuesta con precio y plazo.</p>
    <a class="btn btn-amber mag" href={waLink()} target="_blank" rel="noopener">Escribir por WhatsApp →</a>
  </section>
</Base>

<style>
  /* ===== HERO ===== */
  .hero { position: relative; min-height: 92vh; min-height: 92svh; display: flex; align-items: flex-end; overflow: hidden; }
  .hero .bgwrap { position: absolute; inset: 0; overflow: hidden; transform: scale(1.1); animation: heroZoom 22s ease-out forwards; will-change: transform; }
  .hero img.bg { position: absolute; inset: 0; width: 100%; height: 140%; top: -20%; object-fit: cover; filter: grayscale(.08) contrast(1.06); will-change: transform; }
  @keyframes heroZoom { to { transform: scale(1); } }
  .hero .scrim { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(12,13,16,.5) 0%, rgba(12,13,16,.28) 36%, rgba(12,13,16,.97) 100%); }
  .hero .scrim2 { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(12,13,16,.82), transparent 62%); }
  .hero .grid-ov { position: absolute; inset: 0; background-image: linear-gradient(rgba(237,180,63,.05) 1px, transparent 1px), linear-gradient(90deg, rgba(237,180,63,.05) 1px, transparent 1px); background-size: 48px 48px; mask: radial-gradient(120% 90% at 30% 100%, #000, transparent 75%); }
  .hero .stripe { position: absolute; left: 0; top: 0; bottom: 0; width: 8px; background: repeating-linear-gradient(45deg, var(--amber) 0 14px, #1a1205 14px 28px); opacity: .9; z-index: 3; }
  .hero > .wrap { width: 100%; min-width: 0; position: relative; z-index: 2; }
  .hero .inner { padding: 0 0 72px; max-width: 900px; }
  .hero h1 { font-size: clamp(32px, 6.4vw, 74px); color: #fff; margin: 18px 0 0; text-shadow: 0 2px 30px rgba(0,0,0,.45); overflow-wrap: break-word; }
  .hero h1 b { color: var(--amber); }
  .hero p { font-size: clamp(16px, 1.7vw, 20px); color: #d6dae1; max-width: 560px; margin: 20px 0 30px; }

  /* word / line reveal on load */
  .hwrap { display: flex; flex-wrap: wrap; column-gap: .28em; }
  .hw { opacity: 0; transform: translateY(26px); animation: hwUp .8s cubic-bezier(.2,.7,.2,1) forwards; animation-delay: calc(.1s + var(--i) * .09s); }
  .hwrap .word { display: inline-block; }
  @keyframes hwUp { to { opacity: 1; transform: none; } }

  /* scroll cue */
  .hero-down { position: absolute; left: 50%; bottom: 18px; transform: translateX(-50%); z-index: 3; width: 24px; height: 38px; border: 2px solid rgba(255,255,255,.35); border-radius: 13px; }
  .hero-down span { position: absolute; left: 50%; top: 7px; width: 3px; height: 7px; border-radius: 2px; background: var(--amber); transform: translateX(-50%); animation: scrollCue 1.7s ease-in-out infinite; }
  @keyframes scrollCue { 0%,100% { opacity: 0; top: 7px; } 40% { opacity: 1; } 70% { opacity: 0; top: 20px; } }

  /* ===== TICKER ===== */
  .ticker { overflow: hidden; background: var(--amber); border-top: 3px solid #1a1205; border-bottom: 3px solid #1a1205; }
  .tick-track { display: flex; align-items: center; gap: 22px; width: max-content; white-space: nowrap; animation: tick 34s linear infinite; padding: 11px 0; }
  .ticker:hover .tick-track { animation-play-state: paused; }
  .tick-track span { font-family: var(--h); font-weight: 800; text-transform: uppercase; letter-spacing: .04em; font-size: 15px; color: #1a1205; }
  .tick-track span.sep { font-size: 10px; opacity: .65; }
  @keyframes tick { to { transform: translateX(-50%); } }

  /* ===== OBRAS (galería) ===== */
  .obras { display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: 215px; grid-auto-flow: dense; gap: 12px; }
  .obra { position: relative; overflow: hidden; border-radius: 5px; border: 1px solid var(--line); display: block; padding: 0; cursor: zoom-in; background-color: var(--ink3); background-size: cover; background-position: center; }
  .obra .media { width: 100%; height: 100%; object-fit: cover; transition: transform .6s cubic-bezier(.2,.7,.2,1); }
  .obra:hover .media { transform: scale(1.05); }
  .obra .ov { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 42%, rgba(12,13,16,.82)); pointer-events: none; }
  .obra .lbl { position: absolute; left: 14px; bottom: 13px; z-index: 2; font-family: var(--h); font-weight: 800; text-transform: uppercase; font-size: 13px; letter-spacing: .04em; color: #fff; pointer-events: none; }
  .obra .cat { position: absolute; left: 14px; top: 13px; z-index: 2; font-family: var(--h); font-weight: 700; text-transform: uppercase; font-size: 10px; letter-spacing: .1em; color: var(--amber); opacity: 0; transform: translateY(-5px); transition: .28s; pointer-events: none; }
  .obra:hover .cat { opacity: 1; transform: none; }
  .obra .exp { position: absolute; right: 11px; top: 11px; z-index: 2; width: 30px; height: 30px; border-radius: 4px; background: rgba(12,13,16,.6); display: flex; align-items: center; justify-content: center; opacity: 0; transform: scale(.85); transition: .28s; pointer-events: none; }
  .obra:hover .exp { opacity: 1; transform: none; }
  .obra .exp svg { width: 15px; height: 15px; fill: none; stroke: #fff; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .obra::after { content: ""; position: absolute; left: 0; bottom: 0; width: 100%; height: 3px; background: var(--amber); transform: scaleX(0); transform-origin: left; transition: transform .3s ease; z-index: 3; }
  .obra:hover::after { transform: scaleX(1); }
  .obra.big { grid-column: span 2; grid-row: span 2; }
  .obra.wide { grid-column: span 2; }

  .trust { display: flex; align-items: center; gap: 26px; margin-top: 34px; color: var(--mut); font-size: 15px; flex-wrap: wrap; }
  .trust b { color: #fff; font-family: var(--h); font-weight: 800; letter-spacing: .04em; }

  /* ===== REEL ===== */
  .reel-sec { background: var(--ink2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .reels { display: grid; grid-template-columns: repeat(2, minmax(0, 320px)); gap: 30px; justify-content: center; }
  .reel { position: relative; aspect-ratio: 9 / 16; border-radius: 18px; overflow: hidden; border: 1px solid var(--line2); background: #000; box-shadow: var(--shadow); }
  .reel video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; background: #000; }
  .reel.playing video { object-fit: contain; }
  .reel-grad { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,.35) 0%, transparent 30%, transparent 62%, rgba(0,0,0,.78)); pointer-events: none; transition: opacity .3s; z-index: 1; }
  .reel.playing .reel-grad, .reel.playing .reel-meta, .reel.playing .reel-dur { opacity: 0; pointer-events: none; }
  .reel-play { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); z-index: 2; width: 74px; height: 74px; border-radius: 50%; border: 0; cursor: pointer; background: rgba(237,180,63,.95); display: flex; align-items: center; justify-content: center; transition: transform .2s, background .2s; box-shadow: 0 10px 34px rgba(0,0,0,.5); }
  .reel-play svg { width: 30px; height: 30px; fill: #1a1205; margin-left: 4px; }
  .reel:hover .reel-play { transform: translate(-50%, -50%) scale(1.08); }
  .reel.playing .reel-play { opacity: 0; pointer-events: none; }
  .reel-dur { position: absolute; top: 12px; right: 12px; z-index: 2; background: rgba(12,13,16,.7); color: #fff; font-family: var(--h); font-weight: 700; font-size: 11px; letter-spacing: .05em; padding: 4px 9px; border-radius: 20px; transition: opacity .3s; }
  .reel-meta { position: absolute; left: 16px; right: 16px; bottom: 16px; z-index: 2; transition: opacity .3s; }
  .reel-tag { display: block; font-family: var(--h); font-weight: 800; text-transform: uppercase; font-size: 16px; letter-spacing: .02em; color: #fff; }
  .reel-sub { display: block; color: var(--amber); font-size: 13px; margin-top: 3px; }

  /* ===== TIPOS DE ESPACIOS ===== */
  .uses { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
  .use { position: relative; aspect-ratio: 1; border-radius: 5px; overflow: hidden; display: block; border: 1px solid var(--line); }
  .use img { width: 100%; height: 100%; object-fit: cover; transition: transform .45s ease; filter: grayscale(.3) brightness(.7); }
  .use:hover img { transform: scale(1.08); filter: grayscale(0) brightness(.85); }
  .use-ov { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 40%, rgba(12,13,16,.85)); }
  .use-t { position: absolute; left: 14px; bottom: 13px; z-index: 2; font-family: var(--h); font-weight: 800; text-transform: uppercase; font-size: 15px; letter-spacing: .03em; color: #fff; }
  .use::before { content: ""; position: absolute; left: 0; bottom: 0; width: 100%; height: 3px; background: var(--amber); transform: scaleX(0); transform-origin: left; transition: transform .3s ease; z-index: 3; }
  .use:hover::before { transform: scaleX(1); }

  /* ===== PROCESO ===== */
  .proc-sec { background: var(--ink2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .proc { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; position: relative; }
  .proc-line { position: absolute; top: 27px; left: 8%; right: 8%; height: 2px; background: repeating-linear-gradient(90deg, var(--line2) 0 10px, transparent 10px 18px); transform: scaleX(0); transform-origin: left; transition: transform 1.1s cubic-bezier(.4,0,.2,1); }
  .proc.drawn .proc-line { transform: scaleX(1); }
  .proc-step { text-align: center; position: relative; }
  .proc-num { width: 54px; height: 54px; border-radius: 50%; margin: 0 auto 18px; display: flex; align-items: center; justify-content: center; font-family: var(--h); font-weight: 900; font-size: 22px; color: var(--amber); background: var(--ink); border: 2px solid var(--amber); position: relative; z-index: 1; }
  .proc-step h3 { font-size: 18px; color: #fff; margin-bottom: 8px; text-transform: none; letter-spacing: 0; }
  .proc-step p { color: var(--mut); font-size: 14.5px; max-width: 230px; margin: 0 auto; }

  /* ===== POR QUÉ ===== */
  .why { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .why-card { background: var(--ink2); border: 1px solid var(--line); border-radius: 5px; padding: 26px 24px; transition: .2s; }
  .why-card:hover { border-color: var(--amber); transform: translateY(-4px); }
  .why-ic { width: 38px; height: 38px; color: var(--amber); margin-bottom: 14px; }
  .why-ic svg { width: 100%; height: 100%; fill: none; stroke: currentColor; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
  .why-card h3 { font-size: 18px; color: #fff; margin-bottom: 7px; text-transform: none; letter-spacing: 0; }
  .why-card p { color: var(--mut); font-size: 14.5px; }

  /* ===== VISITÁ LA PLANTA ===== */
  .plant { display: grid; grid-template-columns: 1fr 1fr; gap: 44px; align-items: center; }
  .plant-copy h2 { font-size: clamp(28px, 4vw, 42px); color: #fff; margin: 14px 0 14px; }
  .plant-copy > p { color: var(--mut); font-size: 17px; max-width: 480px; }
  .plant-nap { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-top: 24px; }
  .plant-nap div { color: #c5cad3; font-size: 15px; line-height: 1.6; }
  .plant-nap b { font-family: var(--h); text-transform: uppercase; font-size: 12px; letter-spacing: .08em; color: var(--amber); }
  .plant-nap a:hover { color: var(--amber); }
  .plant-map iframe { width: 100%; height: 380px; border: 1px solid var(--line); border-radius: 6px; filter: grayscale(.2) invert(.92) hue-rotate(180deg) contrast(.9); }
  .map-ph { width: 100%; height: 380px; border: 1px dashed var(--line2); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: #5a6170; }

  /* ===== responsive ===== */
  @media (max-width: 900px) {
    .hero { min-height: 82vh; min-height: 82svh; }
    .hero .inner { padding-bottom: 50px; }
    .cta-row .btn { flex: 1; justify-content: center; }
    .obras { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 180px; }
    .obra.big { grid-column: span 2; grid-row: span 2; }
    .obra.wide { grid-column: span 2; }
    .uses { grid-template-columns: repeat(2, 1fr); }
    .proc { grid-template-columns: 1fr 1fr; gap: 30px; }
    .proc-line { display: none; }
    .why { grid-template-columns: 1fr; }
    .plant { grid-template-columns: 1fr; gap: 26px; }
    .plant-map iframe { height: 300px; }
  }
  @media (max-width: 560px) {
    .reels { grid-template-columns: minmax(0, 300px); }
    .uses { grid-template-columns: 1fr 1fr; }
    .proc { grid-template-columns: 1fr; }
    .plant-nap { grid-template-columns: 1fr; }
    .obras { grid-template-columns: 1fr 1fr; grid-auto-rows: 150px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero .bgwrap { animation: none; transform: none; }
    .hero img.bg { transform: none !important; }
    .hw { animation: none; opacity: 1; transform: none; }
    .tick-track { animation: none; }
    .hero-down span { animation: none; }
    .proc-line { transform: scaleX(1); transition: none; }
  }
</style>

<script is:inline>
  (function () {
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* ---- Count-up ---- */
    function countUp(el) {
      var to = parseInt(el.getAttribute('data-count-to'), 10) || 0, dur = 1100, t0 = null;
      function step(ts) { if (!t0) t0 = ts; var p = Math.min((ts - t0) / dur, 1); el.textContent = Math.round(p * to); if (p < 1) requestAnimationFrame(step); }
      requestAnimationFrame(step);
    }
    var counters = document.querySelectorAll('[data-count-to]');
    if (reduce) { counters.forEach(function (el) { el.textContent = el.getAttribute('data-count-to'); }); }
    else {
      var co = new IntersectionObserver(function (es) { es.forEach(function (e) { if (e.isIntersecting) { countUp(e.target); co.unobserve(e.target); } }); }, { threshold: .6 });
      counters.forEach(function (el) { co.observe(el); });
    }

    /* ---- Line-draw del proceso ---- */
    var proc = document.getElementById('proc');
    if (proc) {
      if (reduce) { proc.classList.add('drawn'); }
      else {
        var po = new IntersectionObserver(function (es) { es.forEach(function (e) { if (e.isIntersecting) { proc.classList.add('drawn'); po.disconnect(); } }); }, { threshold: .4 });
        po.observe(proc);
      }
    }

    /* ---- Reel: click para reproducir ---- */
    document.querySelectorAll('[data-reel]').forEach(function (reel) {
      var v = reel.querySelector('video');
      var btn = reel.querySelector('.reel-play');
      function play() {
        document.querySelectorAll('[data-reel] video').forEach(function (o) { if (o !== v) { o.pause(); o.closest('[data-reel]').classList.remove('playing'); } });
        reel.classList.add('playing');
        v.setAttribute('controls', '');
        v.play();
      }
      btn.addEventListener('click', play);
      v.addEventListener('pause', function () { if (v.currentTime > 0 && !v.ended) { /* keep controls */ } });
      v.addEventListener('ended', function () { reel.classList.remove('playing'); v.removeAttribute('controls'); v.currentTime = 0; });
    });

    /* ---- Lightbox de obras ---- */
    var triggers = Array.prototype.slice.call(document.querySelectorAll('.obra'));
    if (triggers.length) {
      var items = triggers.map(function (t) { return { full: t.getAttribute('data-full'), label: t.getAttribute('data-label') }; });
      var cur = 0;
      var lb = document.createElement('div');
      lb.className = 'lb';
      lb.innerHTML =
        '<span class="lb-count"></span>' +
        '<button class="lb-btn lb-x" aria-label="Cerrar"><svg viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg></button>' +
        '<button class="lb-btn lb-prev" aria-label="Anterior"><svg viewBox="0 0 24 24"><path d="M15 18 9 12l6-6"/></svg></button>' +
        '<button class="lb-btn lb-next" aria-label="Siguiente"><svg viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></button>' +
        '<div class="lb-stage"><img alt=""><div class="lb-cap"></div></div>';
      document.body.appendChild(lb);
      var lbImg = lb.querySelector('img'), lbCap = lb.querySelector('.lb-cap'), lbCount = lb.querySelector('.lb-count');
      function show(i) {
        cur = (i + items.length) % items.length;
        var it = items[cur];
        lbImg.src = it.full; lbImg.alt = it.label;
        lbCap.innerHTML = '<b>Obra</b> · ' + it.label;
        lbCount.textContent = (cur + 1) + ' / ' + items.length;
      }
      function open(i) { show(i); lb.classList.add('open'); document.body.style.overflow = 'hidden'; }
      function close() { lb.classList.remove('open'); document.body.style.overflow = ''; }
      triggers.forEach(function (t, i) { t.addEventListener('click', function () { open(i); }); });
      lb.querySelector('.lb-x').addEventListener('click', close);
      lb.querySelector('.lb-prev').addEventListener('click', function (e) { e.stopPropagation(); show(cur - 1); });
      lb.querySelector('.lb-next').addEventListener('click', function (e) { e.stopPropagation(); show(cur + 1); });
      lb.addEventListener('click', function (e) { if (e.target === lb || e.target.classList.contains('lb-stage')) close(); });
      document.addEventListener('keydown', function (e) {
        if (!lb.classList.contains('open')) return;
        if (e.key === 'Escape') close();
        else if (e.key === 'ArrowLeft') show(cur - 1);
        else if (e.key === 'ArrowRight') show(cur + 1);
      });
      // swipe en mobile
      var sx = 0;
      lb.addEventListener('touchstart', function (e) { sx = e.changedTouches[0].clientX; }, { passive: true });
      lb.addEventListener('touchend', function (e) { var dx = e.changedTouches[0].clientX - sx; if (Math.abs(dx) > 45) show(cur + (dx < 0 ? 1 : -1)); }, { passive: true });
    }
  })();
</script>
